@{
	ViewData["Title"] = "Bad Request";
	Layout = "_Layout";
}

<div class="container min-vh-100 d-flex align-items-center justify-content-center">
	<div class="row w-100 justify-content-center">
		<div class="col-12 col-md-8 col-lg-6">

			<div class="card border-warning shadow-lg">
				<div class="card-header bg-warning text-dark text-center">
					<h1 class="display-5 fw-bold mb-0">400</h1>
				</div>

				<div class="card-body text-center p-5">
					<div class="mb-4">
						<i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 4rem;"></i>
					</div>

					<h2 class="fw-bold mb-3">Bad Request</h2>

					<p class="text-muted fs-5 mb-4">
						Заявката е невалидна или липсва нужният параметър.
					</p>

					<div class="alert alert-warning text-start">
						<strong>Възможна причина:</strong>
						<br />
						Подаден е празен, грешен или невалиден <code>id</code>.
					</div>

					<div class="d-flex gap-2 justify-content-center mt-4">
						<a asp-controller="Cars" asp-action="Index" class="btn btn-primary">
							Back to Cars
						</a>

						<a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
							Home
						</a>
					</div>
				</div>

				<div class="card-footer text-center text-muted small">
					GarageApp MVC Error Page
				</div>
			</div>

		</div>
	</div>
</div>